generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id             String                 @id @default(cuid())
  email          String                 @unique
  password       String                 @default("helloworld")
  name           String?
  image          String?
  emailVerified  DateTime?
  otp            String?                @default("123456")
  otpExpires     DateTime?
  isVerified     Boolean                @default(false)
  role           String                 @default("STUDENT")
  hasPremium     Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  accounts       Account[]
  bookmarks      Bookmark[]
  createdCourses Course[]               @relation("CourseAuthor")
  enrollments    Enrollment[]
  submissions    AssignmentSubmission[]
  notes          Note[]
  questions      Question[]
  replies        Reply[]
  reviews        Review[]
  profile        StudentProfile?
  userProgress   UserProgress[]
  stats          UserStats?
}

model StudentProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  fullName      String
  domain        String?
  collegeName   String?
  collegeDegree String?
  collegeYear   Int?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStats {
  id               String @id @default(cuid())
  userId           String @unique
  videoWatchedMins Int    @default(0)
  questionsSolved  Int    @default(0)
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id           String         @id @default(cuid())
  title        String         @db.VarChar(255)
  description  String?
  imageUrl     String?
  price        Float?
  isPublished  Boolean        @default(false)
  adminId      String
  categoryId   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  admin        User           @relation("CourseAuthor", fields: [adminId], references: [id])
  category     Category?      @relation(fields: [categoryId], references: [id])
  students     Enrollment[]
  modules      Module[]
  UserProgress UserProgress[]

  @@index([title])
}

model Enrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  currentLectureId String?
  enrolledAt       DateTime @default(now())
  course           Course   @relation(fields: [courseId], references: [id])
  currentLecture   Lecture? @relation(fields: [currentLectureId], references: [id])
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Module {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Int
  isPublished Boolean   @default(false)
  courseId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lectures    Lecture[]
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lecture {
  id            String                 @id @default(cuid())
  title         String
  description   String?                @db.Text
  videoUrl      String?
  duration      Int?
  position      Int
  isPublished   Boolean                @default(false)
  isFree        Boolean                @default(false)
  moduleId      String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  textContent   String?
  type          ItemType               @default(VIDEO)
  submissions   AssignmentSubmission[]
  resources     Attachment[]
  bookmarks     Bookmark[]
  enrollments   Enrollment[]
  faqs          FAQ[]
  module        Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  notes         Note[]
  questions     Question[]
  quizQuestions QuizQuestion[]
  reviews       Review[]
  userProgress  UserProgress[]

  @@index([moduleId])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  lectureId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  title     String
  url       String
  type      String   @default("FILE")
  lectureId String
  createdAt DateTime @default(now())
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id               String           @id @default(cuid())
  userId           String
  lectureId        String
  isCompleted      Boolean          @default(false)
  watchTime        Int              @default(0)
  updatedAt        DateTime         @default(now()) @updatedAt
  assignmentStatus AssignmentStatus @default(NOT_SUBMITTED)
  quizScore        Float?
  courseId         String
  Course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecture          Lecture          @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
  @@index([userId, lectureId])
  @@index([userId, courseId])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  userId    String
  lectureId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lecture   Lecture  @relation(fields: [lectureId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  lectureId String
  createdAt DateTime @default(now())
  lecture   Lecture  @relation(fields: [lectureId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, lectureId])
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  courses Course[]
}

model Question {
  id          String          @id @default(cuid())
  title       String          @db.VarChar(255)
  description String
  userId      String
  lectureId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lecture     Lecture         @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  images      QuestionImage[]
  replies     Reply[]

  @@index([userId])
  @@index([lectureId])
}

model QuestionImage {
  id         String   @id @default(cuid())
  url        String
  questionId String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizQuestion {
  id        String         @id @default(cuid())
  text      String
  position  Int
  lectureId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  options   AnswerOption[]
  lecture   Lecture        @relation(fields: [lectureId], references: [id], onDelete: Cascade)
}

model AnswerOption {
  id             String       @id @default(cuid())
  text           String
  isCorrect      Boolean      @default(false)
  quizQuestionId String
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
}

model AssignmentSubmission {
  id        String   @id @default(cuid())
  fileUrl   String
  lectureId String
  studentId String
  user      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade     Float?
  feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([studentId, lectureId])
}

model Reply {
  id         String   @id @default(cuid())
  content    String
  questionId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

model Bookmark {
  id        String       @id @default(cuid())
  time      Float
  label     String?
  type      BookmarkType @default(BOOKMARK)
  userId    String
  lectureId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lecture   Lecture      @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lectureId])
}

enum ItemType {
  VIDEO
  LIVE
  TEXT
  QUIZ
  ASSIGNMENT
}

enum BookmarkType {
  BOOKMARK
  IMPORTANT
  QUESTION
  RESOURCE
}

enum AssignmentStatus {
  NOT_SUBMITTED
  SUBMITTED
  GRADED
}
