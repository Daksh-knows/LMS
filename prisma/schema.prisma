generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  password             String                 @default("helloworld")
  name                 String?
  image                String?
  emailVerified        DateTime?
  otp                  String?                @default("123456")
  otpExpires           DateTime?
  isVerified           Boolean                @default(false)
  role                 String                 @default("STUDENT")
  hasPremium           Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  hasRegistered        Boolean                @default(false)
  batch                String?                @default("Batch 1")
  bio                  String?
  isTempPassword       Boolean                @default(true)
  resetToken           String?
  resetTokenExpiry     DateTime?
  accounts             Account[]
  AssignmentSubmission AssignmentSubmission[]
  bookmarks            Bookmark[]
  createdCourses       Course[]               @relation("CourseAuthor")
  createdBundles       CourseBundle[]         @relation("BundleAuthor")
  enrollments          MyEnrollment[]
  notes                Note[]
  notifications        Notification[]
  payments             Payment[]
  questions            Question[]
  refundRequests       RefundRequest[]
  replies              Reply[]
  reviews              Review[]
  profile              StudentProfile?
  supportMessages      SupportMessage[]
  tickets              SupportTicket[]
  userProgress         UserProgress[]
  stats                UserStats?
}

model StudentProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  fullName      String
  domain        String?
  collegeName   String?
  collegeDegree String?
  collegeYear   Int?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStats {
  id               String @id @default(cuid())
  userId           String @unique
  videoWatchedMins Int    @default(0)
  questionsSolved  Int    @default(0)
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id                String         @id @default(cuid())
  title             String         @db.VarChar(255)
  description       String?
  imageUrl          String?
  price             Float?
  isPublished       Boolean        @default(false)
  adminId           String
  categoryId        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  estimatedDuration String?
  language          String?        @default("English")
  subtitle          String?
  isCompleted       Boolean        @default(false)
  type              CourseType     @default(PREMIUM)
  admin             User           @relation("CourseAuthor", fields: [adminId], references: [id])
  category          Category?      @relation(fields: [categoryId], references: [id])
  students          MyEnrollment[]
  modules           Module[]
  notifications     Notification[]
  userProgress      UserProgress[]
  bundles           CourseBundle[]
  payments          Payment[]

  @@index([title])
}

model MyEnrollment {
  id               String   @id @default(cuid())
  userId           String
  courseId         String
  currentLectureId String?
  enrolledAt       DateTime @default(now())
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  currentLecture   Lecture? @relation(fields: [currentLectureId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("Enrollment")
}

model Module {
  id          String    @id @default(cuid())
  title       String
  description String?
  position    Int
  isPublished Boolean   @default(false)
  courseId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lectures    Lecture[]
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Lecture {
  id            String                 @id @default(cuid())
  title         String
  description   String?
  videoUrl      String?
  duration      Int?
  position      Int
  isPublished   Boolean                @default(false)
  isFree        Boolean                @default(false)
  moduleId      String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  textContent   String?
  type          ItemType               @default(VIDEO)
  submissions   AssignmentSubmission[]
  resources     Attachment[]
  bookmarks     Bookmark[]
  enrollments   MyEnrollment[]
  faqs          FAQ[]
  module        Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  notes         Note[]
  questions     Question[]
  quizQuestions QuizQuestion[]
  reviews       Review[]
  userProgress  UserProgress[]

  @@index([moduleId])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  lectureId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  title     String
  url       String
  type      String   @default("FILE")
  lectureId String
  createdAt DateTime @default(now())
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id               String           @id @default(cuid())
  userId           String
  lectureId        String
  isCompleted      Boolean          @default(false)
  watchTime        Int              @default(0)
  updatedAt        DateTime         @default(now()) @updatedAt
  assignmentStatus AssignmentStatus @default(NOT_SUBMITTED)
  quizScore        Float?
  courseId         String
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecture          Lecture          @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
  @@index([userId, lectureId])
  @@index([userId, courseId])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  userId    String
  lectureId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  lectureId String
  createdAt DateTime @default(now())
  lecture   Lecture  @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  courses Course[]
}

model Question {
  id          String          @id @default(cuid())
  title       String          @db.VarChar(255)
  description String
  userId      String
  lectureId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lecture     Lecture         @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  images      QuestionImage[]
  replies     Reply[]

  @@index([userId])
  @@index([lectureId])
}

model QuestionImage {
  id         String   @id @default(cuid())
  url        String
  questionId String
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizQuestion {
  id        String         @id @default(cuid())
  text      String
  position  Int
  lectureId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  options   AnswerOption[]
  lecture   Lecture        @relation(fields: [lectureId], references: [id], onDelete: Cascade)
}

model AnswerOption {
  id             String       @id @default(cuid())
  text           String
  isCorrect      Boolean      @default(false)
  quizQuestionId String
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
}

model AssignmentSubmission {
  id        String           @id @default(cuid())
  fileUrl   String
  lectureId String
  studentId String
  grade     Float?
  feedback  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  status    AssignmentStatus @default(NOT_SUBMITTED)
  lecture   Lecture          @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  User      User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lectureId])
}

model Reply {
  id         String   @id @default(cuid())
  content    String
  questionId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

model Bookmark {
  id        String       @id @default(cuid())
  startTime      Float
  endTime      Float
  label     String?
  type      BookmarkType @default(BOOKMARK)
  userId    String
  lectureId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lecture   Lecture      @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lectureId])
}

model Payment {
  id                String         @id @default(cuid())
  amount            Float
  currency          String         @default("INR")
  status            String         @default("SUCCESS")
  method            String?
  planType          String
  razorpayOrderId   String         @unique
  razorpayPaymentId String         @unique
  razorpaySignature String
  userId            String
  createdAt         DateTime       @default(now())
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refundRequest     RefundRequest?

  courseId          String?
  bundleId          String?
  course            Course?        @relation(fields: [courseId], references: [id])
  bundle            CourseBundle?  @relation(fields: [bundleId], references: [id])
}

model RefundRequest {
  id        String       @id @default(cuid())
  reason    String
  status    RefundStatus @default(PENDING)
  userId    String
  paymentId String?      @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  payment   Payment?     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String           @id @default(cuid())
  subject   String
  status    TicketStatus     @default(OPEN)
  priority  TicketPriority   @default(MEDIUM)
  userId    String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  SupportMessage[]
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportMessage {
  id        String        @id @default(cuid())
  message   String
  ticketId  String
  senderId  String
  createdAt DateTime      @default(now())
  sender    User          @relation(fields: [senderId], references: [id])
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model UserActivity {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  duration  Int          @default(0)
  createdAt DateTime     @default(now())

  @@unique([userId, type, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  actionUrl String?
  isRead    Boolean          @default(false)
  type      NotificationType @default(SYSTEM)
  courseId  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course?          @relation(fields: [courseId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model CourseBundle {
  id          String    @id @default(cuid())
  title       String
  description String?
  price       Float
  isPublished Boolean   @default(false)
  adminId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  admin       User      @relation("BundleAuthor", fields: [adminId], references: [id])
  courses     Course[]
  payments    Payment[]
}

enum ItemType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
  LIVE
}

enum AssignmentStatus {
  NOT_SUBMITTED
  SUBMITTED
  GRADED
}

enum BookmarkType {
  BOOKMARK
  IMPORTANT
  QUESTION
  RESOURCE
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  VIDEO_WATCH
  QUIZ_ATTEMPT
  ASSIGNMENT_SUBMISSION
}

enum CourseType {
  CRASH
  PREMIUM
}

enum NotificationType {
  SYSTEM
  COURSE_UPDATE
  ASSIGNMENT
  MENTION
  BILLING
}
